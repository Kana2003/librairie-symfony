{% extends 'base.html.twig' %}

{% block title %}Acheter {{ book.title }} - E-commerce Livres Informatiques{% endblock %}

{% block body %}
<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3>💳 Achat direct</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-4">
                        <img src="{{ asset('images/books/' ~ book.image) }}" 
                             alt="{{ book.title }}" 
                             class="img-fluid rounded"
                             onerror="this.src='{{ asset('images/books/Illustration-ordinateur-portable-ouvert.jpg') }}'">
                    </div>
                    <div class="col-md-8">
                        <h4>{{ book.title }}</h4>
                        <p class="text-muted">Par {{ book.author }}</p>
                        <p>{{ book.description }}</p>
                        
                        <div class="mb-3">
                            <span class="badge bg-{{ book.stock > 5 ? 'success' : (book.stock > 0 ? 'warning' : 'danger') }}">
                                {{ book.status }}
                            </span>
                        </div>

                        <div class="alert alert-info">
                            <h6>📋 Informations importantes</h6>
                            <ul class="mb-0">
                                <li>Vous devez être connecté pour finaliser votre achat</li>
                                <li>Le paiement se fera via PayPal</li>
                                <li>Les taxes québécoises (14.975%) seront ajoutées</li>
                                <li>Livraison gratuite pour toute commande</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5>Résumé de l'achat</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label for="quantity" class="form-label">Quantité</label>
                        <select name="quantity" id="quantity" class="form-select" required>
                            {% for i in 1..min(book.stock, 10) %}
                                <option value="{{ i }}">{{ i }}</option>
                            {% endfor %}
                        </select>
                        <div class="form-text">Maximum {{ book.stock }} exemplaires disponibles</div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span>Prix unitaire :</span>
                            <span>{{ book.price|number_format(2, ',', ' ') }} $ CAD</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Taxes (14.975%) :</span>
                            <span>{{ (book.price * 0.14975)|number_format(2, ',', ' ') }} $ CAD</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between fw-bold">
                            <span>Total estimé :</span>
                            <span>{{ (book.price * 1.14975)|number_format(2, ',', ' ') }} $ CAD</span>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">
                            💳 Procéder à l'achat
                        </button>
                        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">
                            ← Retour aux livres
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Actions alternatives -->
        <div class="card mt-3">
            <div class="card-body">
                <h6>Autres options</h6>
                <div class="d-grid gap-2">
                    <form method="post" action="{{ path('app_guest_cart_add', {'id': book.id}) }}">
                        <input type="hidden" name="quantity" value="1">
                        <button type="submit" class="btn btn-outline-primary">
                            🛒 Ajouter au panier invité
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
