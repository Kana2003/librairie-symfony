{% extends 'base.html.twig' %}

{% block title %}Modifier {{ book.title }} - Administration{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3>✏️ Modifier le livre</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-4">
                            {% if book.image %}
                                <img src="{{ asset('images/books/' ~ book.image) }}" 
                                     alt="{{ book.title }}" 
                                     class="img-fluid rounded"
                                     onerror="this.src='{{ asset('images/books/Illustration-ordinateur-portable-ouvert.jpg') }}'">
                            {% else %}
                                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 200px;">
                                    <span class="text-muted">Aucune image</span>
                                </div>
                            {% endif %}
                        </div>
                        <div class="col-md-8">
                            <h5>{{ book.title }}</h5>
                            <p class="text-muted">Par {{ book.author }}</p>
                            <p>{{ book.description|slice(0, 100) }}{% if book.description|length > 100 %}...{% endif %}</p>
                            <div class="d-flex gap-2">
                                <span class="badge bg-primary">{{ book.price|number_format(2, ',', ' ') }} $ CAD</span>
                                <span class="badge bg-{{ book.stock > 5 ? 'success' : (book.stock > 0 ? 'warning' : 'danger') }}">
                                    {{ book.status }}
                                </span>
                            </div>
                        </div>
                    </div>

                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.title, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': 'Titre du livre'
                                }
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.author, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': 'Nom de l\'auteur'
                                }
                            }) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.description, {
                            'attr': {
                                'class': 'form-control',
                                'rows': '4',
                                'placeholder': 'Description détaillée du livre'
                            }
                        }) }}
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.price, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': '0.00'
                                }
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.stock, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': '0'
                                }
                            }) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.imageFile, {
                            'attr': {
                                'class': 'form-control'
                            }
                        }) }}
                        <small class="form-text text-muted">
                            Laissez vide pour conserver l'image actuelle. Formats acceptés : JPG, PNG, GIF (max 1MB)
                        </small>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="{{ path('admin_book_index') }}" class="btn btn-outline-secondary">
                            ← Retour à la liste
                        </a>
                        <button type="submit" class="btn btn-primary">
                            💾 Enregistrer les modifications
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
