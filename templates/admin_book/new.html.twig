{% extends 'base.html.twig' %}

{% block title %}Ajouter un livre - Administration{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3>📚 Ajouter un nouveau livre</h3>
                </div>
                <div class="card-body">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                    
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.title, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': 'Titre du livre'
                                }
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.author, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': 'Nom de l\'auteur'
                                }
                            }) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.description, {
                            'attr': {
                                'class': 'form-control',
                                'rows': '4',
                                'placeholder': 'Description détaillée du livre'
                            }
                        }) }}
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.price, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': '0.00'
                                }
                            }) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.stock, {
                                'attr': {
                                    'class': 'form-control',
                                    'placeholder': '0'
                                }
                            }) }}
                        </div>
                    </div>

                    <div class="mb-3">
                        {{ form_row(form.imageFile, {
                            'attr': {
                                'class': 'form-control'
                            }
                        }) }}
                        <small class="form-text text-muted">
                            Formats acceptés : JPG, PNG, GIF (max 1MB)
                        </small>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="{{ path('admin_book_index') }}" class="btn btn-outline-secondary">
                            ← Retour à la liste
                        </a>
                        <button type="submit" class="btn btn-primary">
                            ✅ Ajouter le livre
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
