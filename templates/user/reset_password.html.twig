{% extends 'base.html.twig' %}

{% block title %}Changer le mot de passe - E-commerce Livres Informatiques{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header text-center">
                <h3>🔐 Changer le mot de passe</h3>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_row(form.currentPassword, {
                        'attr': {'class': 'form-control'},
                        'label_attr': {'class': 'form-label'}
                    }) }}

                    {{ form_row(form.newPassword.first, {
                        'attr': {'class': 'form-control'},
                        'label_attr': {'class': 'form-label'}
                    }) }}

                    {{ form_row(form.newPassword.second, {
                        'attr': {'class': 'form-control'},
                        'label_attr': {'class': 'form-label'}
                    }) }}

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            🔐 Changer le mot de passe
                        </button>
                        <a href="{{ path('app_user_profile') }}" class="btn btn-outline-secondary">
                            ← Retour au profil
                        </a>
                    </div>
                {{ form_end(form) }}

                <hr>

                <div class="alert alert-info">
                    <h6>💡 Conseils pour un mot de passe sécurisé :</h6>
                    <ul class="mb-0">
                        <li>Utilisez au moins 8 caractères</li>
                        <li>Combinez lettres majuscules et minuscules</li>
                        <li>Ajoutez des chiffres et des symboles</li>
                        <li>Évitez les informations personnelles</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
