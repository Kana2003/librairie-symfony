{% extends 'base.html.twig' %}

{% block title %}Vérification du code - E-commerce Livres Informatiques{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="card">
            <div class="card-header text-center">
                <h3>🔐 Vérification du code</h3>
            </div>
            <div class="card-body">
                <div class="alert alert-success">
                    <h6>📧 Code envoyé !</h6>
                    <p class="mb-0">Vérifiez votre boîte email et entrez le code de vérification à 6 chiffres.</p>
                </div>

                <form method="post">
                    <div class="mb-3">
                        <label for="otp" class="form-label">Code de vérification</label>
                        <input type="text" id="otp" name="otp" class="form-control" 
                               maxlength="6" pattern="[0-9]{6}" 
                               placeholder="123456" required autofocus>
                        <div class="form-text">Entrez le code à 6 chiffres reçu par email</div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            ✅ Vérifier le code
                        </button>
                        
                        <form method="post" action="{{ path('app_2fa_resend') }}" style="display: inline;">
                            <button type="submit" class="btn btn-outline-secondary">
                                📧 Renvoyer le code
                            </button>
                        </form>
                    </div>
                </form>

                <hr>

                <div class="text-center">
                    <p class="text-muted small">
                        <strong>💡 Conseil :</strong> Le code expire dans 10 minutes.<br>
                        Vérifiez aussi vos spams si vous ne recevez pas l'email.
                    </p>
                    
                    <a href="{{ path('app_2fa_request') }}" class="btn btn-outline-secondary btn-sm">
                        ← Retour
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Auto-focus et formatage du champ OTP
document.getElementById('otp').addEventListener('input', function(e) {
    // Supprimer tous les caractères non numériques
    this.value = this.value.replace(/[^0-9]/g, '');
    
    // Limiter à 6 chiffres
    if (this.value.length > 6) {
        this.value = this.value.slice(0, 6);
    }
});
</script>
{% endblock %}
